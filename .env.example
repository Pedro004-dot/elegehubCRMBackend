# ===========================================
# ElegeHub CRM Backend - Environment Variables
# ===========================================

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# Google Cloud (BigQuery) - Required for TSE data from Base dos Dados
# 1. Create a project in Google Cloud Console
# 2. Enable BigQuery API
# 3. Create a Service Account and download the JSON key
# 4. Set the path to the key file below
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Server Configuration
PORT=3001
NODE_ENV=development

# ===========================================
# Notes
# ===========================================
#
# BigQuery (Base dos Dados):
# - Free tier: 1TB/month of queries
# - The Base dos Dados project is public, so you only need
#   authentication to run queries
# - More info: https://basedosdados.org/docs
#
# Running ETL:
# - npm run db:seed        # Run all ETL steps
# - npm run db:seed:fast   # Skip optional steps (populacao, geojson)
# - npm run etl:ibge:*     # Run individual IBGE ETL
# - npm run etl:tse:*      # Run individual TSE ETL
